{
  "entities": {
    "Post": {
      "title": "Blog Post",
      "description": "A single blog post entry",
      "type": "object",
      "required": ["title", "content", "createdAt", "slug"],
      "properties": {
        "title": { "type": "string", "description": "The title of the post" },
        "content": { "type": "string", "description": "The markdown content of the post" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of post creation" },
        "slug": { "type": "string", "description": "URL-friendly version of the title" },
        "author": { "type": "string", "description": "ID of the author" }
      }
    },
    "AnalyticsMetrics": {
      "title": "Analytics Metrics",
      "description": "Historical analytics metrics for different periods",
      "type": "object",
      "properties": {
        "data": { "type": "array", "description": "Array of names, Google Clicks, AI Citations and CTR numbers" }
      }
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Collection of blog posts"
    },
    "/analytics_metrics/{id}": {
      "schema": { "$ref": "#/entities/AnalyticsMetrics" },
      "description": "Historical performance matrices"
    }
  }
}
